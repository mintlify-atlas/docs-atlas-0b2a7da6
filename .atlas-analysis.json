  "keyFeatures": [
    "Plugin Manager with WordPress.org search, install, update, version history, and ZIP upload/export",
    "Theme Manager with activation, deletion, WP.org install, version history, and ZIP export",
    "File Manager with Monaco Editor (VS Code engine), full filesystem browsing, and path traversal protection",
    "Database Manager with table browser, row CRUD, SQL runner, search & replace, and SQL dump export",
    "User Manager with role management, admin impersonation (Login As), and user operations",
    "Security Suite: Admin URL protection, login limiter, IP blocklist, core integrity check, and TOTP 2FA",
    "Security Scanner: malware detection, vulnerability check (WPScan API), SSL monitor, core version check",
    "Maintenance Mode with custom appearance, gradient presets, countdown timer, and live preview",
    "Agency Tools: mail interceptor, white-label login page, admin UI customiser, client report generator, coming soon mode",
    "Developer Utilities: hook explorer, REST API tester, dummy data generator, rewrite rules tester, object cache browser",
    "Image Tools with WebP/AVIF conversion, batch conversion, thumbnail regeneration, SVG upload support",
    "Cron Manager with event scheduling, manual trigger, custom schedules, and health monitoring",
    "Code Snippets with Monaco Editor for PHP/CSS/JS execution from the dashboard",
    "Database Backup with scheduled backups, table-specific dumps, and protected storage",
    "Media Manager with orphaned/unused/duplicate detection and JPEG/PNG compression"
  ],
